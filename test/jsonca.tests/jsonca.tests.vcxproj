  <Import Project="..\..\packages\WixToolset.WcaUtil.6.0.1\build\WixToolset.WcaUtil.props" Condition="Exists('..\..\packages\WixToolset.WcaUtil.6.0.1\build\WixToolset.WcaUtil.props')" />
