<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:Json="http://schemas.hegsie.com/wix/JsonExtension">
  <Fragment>
    <ComponentGroup Id="TestComponents" Directory="INSTALLFOLDER">
      <Component Id="ConfigComponent" Guid="*">
        <File Id="ConfigJson" Source="config.json" />
        <!-- JsonFile does not allow child elements; the compiler must report this rather than
             silently ignore it (regression guard for the discarded-ErrorMessages fix). -->
        <Json:JsonFile Id="WithChild" File="[#ConfigJson]" ElementPath="$.config.value" Value="x" Action="setValue">
          <Json:Unexpected />
        </Json:JsonFile>
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
