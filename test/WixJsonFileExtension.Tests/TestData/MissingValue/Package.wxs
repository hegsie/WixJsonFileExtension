<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:Json="http://schemas.hegsie.com/wix/JsonExtension">
  <Fragment>
    <ComponentGroup Id="TestComponents" Directory="INSTALLFOLDER">
      <Component Id="ConfigComponent" Guid="*">
        <File Id="ConfigJson" Source="config.json" />
        <!-- setValue with no Value attribute: the compiler must report ExpectedAttribute. -->
        <Json:JsonFile Id="SetValueBad" File="[#ConfigJson]" ElementPath="$.config.value" Action="setValue" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
